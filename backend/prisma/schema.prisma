generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Place {
  id          String   @id @default(uuid())
  osmId       String?  @unique
  name        String
  lat         Float
  lon         Float
  catKey      String
  description String?
  image       String?
  rating      Float?   @default(4.5)
  tags        Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([catKey])
}

model Category {
  id    String @id
  label String
  icon  String
  color String
}
